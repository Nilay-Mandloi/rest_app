# ---------------------------------------------------------------------------
# AWS credentials — only needed for the training-trigger + discovery endpoints
# (/trigger-train, /projects/...). The prediction path never touches AWS: the
# model is baked into the image at build time. boto3 reads these from its
# default credential chain.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# Baked model — written into the image during `docker build` (see Dockerfile).
# Override only if you mount the artifacts somewhere other than /app.
# ---------------------------------------------------------------------------
MODEL_PKL_PATH=/app/model.pkl
MANIFEST_PATH=/app/manifest.json

# ---------------------------------------------------------------------------
# S3 location for the discovery + trigger endpoints. The bucket defaults to
# "{category}-artifacts" when left blank (matches the training repo's
# bucket_for() convention).
# ---------------------------------------------------------------------------
ARTIFACT_STORE_BUCKET=
ARTIFACT_STORE_PREFIX=

# ---------------------------------------------------------------------------
# Service
# ---------------------------------------------------------------------------
APP_ADMIN_TOKEN=change-me
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_BATCH_SIZE=1000

# ---------------------------------------------------------------------------
# Training trigger (/trigger-train). Endpoint returns 503 if either of the
# first two are unset. The PAT must have contents:read + actions:write on
# the GITHUB_TRAINING_REPO. Auth on the endpoint itself is APP_ADMIN_TOKEN.
# ---------------------------------------------------------------------------
GITHUB_TRAINING_REPO=
GITHUB_PAT=
TRAINING_AUTO_PROMOTE=false
MAX_DATASET_BYTES=104857600   # 100 MB
