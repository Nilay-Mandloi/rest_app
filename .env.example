# ---------------------------------------------------------------------------
# AWS credentials (required) — set in GitHub Secrets in CI, in environment
# locally. boto3 picks these up automatically via its default credential chain.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ---------------------------------------------------------------------------
# Optional defaults — applied to /predict requests that omit them in the body.
# Leave all three blank to run as a pure multi-model gateway where callers
# always specify (category, project, model_name) on every request.
# When all three are set, the model is preloaded into the cache at startup.
# ---------------------------------------------------------------------------
DEFAULT_CATEGORY=mlops
DEFAULT_PROJECT=product_dq
DEFAULT_MODEL_NAME=sentiment_analysis
DEFAULT_CHANNEL=stable

# ---------------------------------------------------------------------------
# S3 location overrides. The bucket defaults to "{category}-artifacts" when
# left blank (matches the training repo's bucket_for() convention).
# ---------------------------------------------------------------------------
ARTIFACT_STORE_BUCKET=
ARTIFACT_STORE_PREFIX=

# ---------------------------------------------------------------------------
# Service
# ---------------------------------------------------------------------------
APP_ADMIN_TOKEN=change-me
APP_HOST=0.0.0.0
APP_PORT=8000

# Bounded LRU of loaded models. Each entry holds a deserialised pickle in
# memory; tune based on RAM and how many distinct (project, model, version)
# tuples this instance serves.
CACHE_MAX_ENTRIES=8
MAX_BATCH_SIZE=1000
